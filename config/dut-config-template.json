        {
          "Id": "step_001",
          "Name": "测试步骤1",
          "Description": "测试步骤描述",
          "Order": 1,
          "Enabled": true,
          "Target": "dut",
          "Type": "custom",
          "Command": "测试命令",
          "Expected": "contains:期望结果",
          "Timeout": 5000,
          "Delay": 500,
          "Channel": "Cmd"
        }
      ]
    }
