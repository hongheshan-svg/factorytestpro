    "Description": "产品专用测试配置 - 根据实际产品修改",
    "Author": "UTF System"
  },
  
  "SystemSettings": {
    "LogLevel": "Info",
    "AutoSaveResults": true,
    "ResultsPath": "./test-results",
    "BackupEnabled": true,
    "MaxLogFiles": 10,
    "LogRotationSizeMB": 50,
    "DefaultLanguage": "zh-CN",
    "Theme": "Light",
    "AutoRefresh": true,
    "RefreshInterval": 2000
  },
  
  "DUTConfiguration": {
    "ProductInfo": {
      "Name": "产品名称",
      "Model": "产品型号",
      "Icon": "🔧",
      "Category": "产品类别",
      "ExpectedSoftwareVersion": "期望的软件版本"
    },
    
    "GlobalSettings": {
      "DefaultMaxConcurrent": 16,
      "EnablePreTestCheck": true,
      "DefaultVoltage": 5.0,
      "DefaultCurrent": 0.5,
      "TestTimeout": 300,
      "RetryCount": 3,
      "RetryDelay": 2000
    },
    
    "MacRanges": [
      { "start": "00:00:00:00:00:00", "end": "00:00:00:00:00:00" }
