{
  "ConfigurationInfo": {
    "Name": "QQ公仔测试配置",
    "Version": "1.0.0",
    "CreatedDate": "2024-01-01T00:00:00Z",
    "Description": "QQ公仔产品专用测试配置",
    "Author": "UTF System"
  },
  
  "SystemSettings": {
    "LogLevel": "Info",
    "AutoSaveResults": true,
    "ResultsPath": "./test-results",
    "BackupEnabled": true,
    "MaxLogFiles": 10,
    "LogRotationSizeMB": 50,
    "DefaultLanguage": "zh-CN",
    "Theme": "Light",
    "AutoRefresh": true,
    "RefreshInterval": 2000
  },
  
  "DUTConfiguration": {
    "ProductInfo": {
      "Name": "QQ公仔",
      "Model": "QQ公仔1.0",
      "Icon": "🐧",
      "Category": "消费电子产品",
      "ExpectedSoftwareVersion": "SW_VERSION:V1.0"
    },
    
    "GlobalSettings": {
      "DefaultMaxConcurrent": 16,
      "EnablePreTestCheck": true,
      "DefaultVoltage": 3.8,
      "DefaultCurrent": 0.5,
      "TestTimeout": 300,
      "RetryCount": 3,
      "RetryDelay": 2000
    },
    
    "MacRanges": [
      { "start": "1C:78:39:09:F4:28", "end": "1C:78:39:09:FF:14" },
      { "start": "1C783909F428", "end": "1C783909FF14" }
    ],
    
    "Connections": {
      "Primary": {
        "Type": "Serial",
        "BaudRate": 115200,
        "DataBits": 8,
        "StopBits": 1,
        "Parity": "None"
      },
      "Secondary": {
        "Type": "Network",
        "TelnetPort": 23,
        "IPRange": "192.168.1.10-192.168.1.20"
      }
    },
    
    "CommunicationEndpoints": {
      "SerialPorts": [
        "COM3", "COM4", "COM5", "COM6", "COM7", "COM8", "COM9", "COM10",
        "COM11", "COM12", "COM13", "COM14", "COM15", "COM16"
      ],
      "NetworkHosts": [
        "192.168.1.10", "192.168.1.11", "192.168.1.12", "192.168.1.13",
        "192.168.1.14", "192.168.1.15", "192.168.1.16", "192.168.1.17",
        "192.168.1.18", "192.168.1.19", "192.168.1.20", "192.168.1.21",
        "192.168.1.22", "192.168.1.23", "192.168.1.24", "192.168.1.25"
      ]
    },
    
    "NamingConfig": {
      "Template": "{TypeName}测试工位{Index}",
      "IdTemplate": "DUT-{Index}"
    }
  },
  
  "TestProjectConfiguration": {
    "TestMode": {
      "Id": "production",
      "Name": "生产测试",
      "Icon": "🏭",
      "Description": "QQ公仔生产线完整测试流程",
      "DefaultTimeout": 300000,
      "EnableParallel": true,
      "MaxRetries": 2
    },
    
    "TestProject": {
      "Id": "qq_doll_production_test",
      "Name": "QQ公仔生产测试",
      "Description": "QQ公仔完整生产测试流程",
      "Enabled": true,
      "Steps": [
        {
          "Id": "step_001",
          "Name": "网络连接测试",
          "Description": "通过ping命令测试网络连接",
          "Order": 1,
          "Enabled": true,
          "Target": "dut",
          "Type": "custom",
          "Command": "ping -n 2 www.qq.com",
          "Expected": "contains:来自",
          "Timeout": 10000,
          "Delay": 1000,
          "Channel": "Cmd"
        },
        {
          "Id": "step_002",
          "Name": "软件版本检查",
          "Description": "通过串口检查DUT软件版本",
          "Order": 2,
          "Enabled": true,
          "Target": "dut",
          "Type": "serial",
          "Command": "system_manager version",
          "Expected": "contains:SW_VERSION:V1.0",
          "Timeout": 5000,
          "Delay": 500,
          "Channel": "Serial"
        },
        {
          "Id": "step_003",
          "Name": "MAC地址检查",
          "Description": "检查DUT的MAC地址是否在有效范围内",
          "Order": 3,
          "Enabled": true,
          "Target": "dut",
          "Type": "serial",
          "Command": "mac",
          "Expected": "contains:1C:78:39",
          "Timeout": 5000,
          "Delay": 500,
          "Channel": "Serial"
        },
        {
          "Id": "step_004",
          "Name": "音频功能测试",
          "Description": "执行工厂音频测试",
          "Order": 4,
          "Enabled": true,
          "Target": "dut",
          "Type": "serial",
          "Command": "system_manager factory_test",
          "Expected": "contains:test voice pass",
          "Timeout": 25000,
          "Delay": 1000,
          "Channel": "Serial"
        }
      ]
    }
  }
}
