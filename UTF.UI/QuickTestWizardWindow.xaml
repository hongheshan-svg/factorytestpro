<Window x:Class="UTF.UI.QuickTestWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="快速创建测试 - 向导" Height="720" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#F0F2F5" ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- 主按钮样式 -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 次要按钮 -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E4E6EB"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 成功按钮 -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#28A745"/>
        </Style>

        <!-- 卡片边框 -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.08" Color="Gray"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 输入框 -->
        <Style x:Key="WizardTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 标签 -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- 步骤指示器文字 -->
        <Style x:Key="StepIndicator" TargetType="Border">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="#E4E6EB"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════ 标题栏 ═══════════ -->
        <Border Grid.Row="0" Background="White" Padding="24,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.06" Color="Gray"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="🚀 快速创建测试" FontSize="20" FontWeight="Bold" Foreground="#1A1A2E"/>
                <TextBlock Text="三步完成测试配置，无需编写任何代码" FontSize="12" Foreground="#888" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- ═══════════ 步骤指示器 ═══════════ -->
        <Border Grid.Row="1" Background="White" Padding="24,12" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Step 1 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border x:Name="Step1Circle" Width="32" Height="32" CornerRadius="16" Background="#007ACC">
                        <TextBlock Text="1" FontSize="14" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="Step1Label" Text="产品信息" FontSize="13" FontWeight="SemiBold"
                               Foreground="#007ACC" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Line 1 -->
                <Border Grid.Column="1" Height="2" Width="60" Background="#E0E0E0" VerticalAlignment="Center"
                        x:Name="Line1"/>

                <!-- Step 2 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border x:Name="Step2Circle" Width="32" Height="32" CornerRadius="16" Background="#E4E6EB">
                        <TextBlock Text="2" FontSize="14" FontWeight="Bold" Foreground="#888"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   x:Name="Step2Number"/>
                    </Border>
                    <TextBlock x:Name="Step2Label" Text="测试步骤" FontSize="13"
                               Foreground="#888" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Line 2 -->
                <Border Grid.Column="3" Height="2" Width="60" Background="#E0E0E0" VerticalAlignment="Center"
                        x:Name="Line2"/>

                <!-- Step 3 -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border x:Name="Step3Circle" Width="32" Height="32" CornerRadius="16" Background="#E4E6EB">
                        <TextBlock Text="3" FontSize="14" FontWeight="Bold" Foreground="#888"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   x:Name="Step3Number"/>
                    </Border>
                    <TextBlock x:Name="Step3Label" Text="预览保存" FontSize="13"
                               Foreground="#888" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════ 主内容区域 ═══════════ -->
        <Grid Grid.Row="2" Margin="24,0">

            <!-- ───── 第1步：产品信息 ───── -->
            <ScrollViewer x:Name="Step1Panel" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="📦 产品基本信息" FontSize="15" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,16"/>

                            <TextBlock Text="产品名称 *" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="WizProductName" Style="{StaticResource WizardTextBox}" Margin="0,0,0,12"
                                     TextChanged="OnProductInfoChanged"/>

                            <TextBlock Text="产品型号 *" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="WizProductModel" Style="{StaticResource WizardTextBox}" Margin="0,0,0,12"
                                     TextChanged="OnProductInfoChanged"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="产品类别" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="WizProductCategory" FontSize="13" Padding="6,6" IsEditable="True">
                                        <ComboBoxItem Content="消费电子产品"/>
                                        <ComboBoxItem Content="汽车电子"/>
                                        <ComboBoxItem Content="工业设备"/>
                                        <ComboBoxItem Content="通信设备"/>
                                        <ComboBoxItem Content="智能家居"/>
                                        <ComboBoxItem Content="医疗设备"/>
                                        <ComboBoxItem Content="其他"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="产品图标" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="WizProductIcon" FontSize="16" Padding="6,4">
                                        <ComboBoxItem Content="📱" IsSelected="True"/>
                                        <ComboBoxItem Content="🖥️"/>
                                        <ComboBoxItem Content="🔧"/>
                                        <ComboBoxItem Content="🎮"/>
                                        <ComboBoxItem Content="🔌"/>
                                        <ComboBoxItem Content="💡"/>
                                        <ComboBoxItem Content="🚗"/>
                                        <ComboBoxItem Content="🏭"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="🔗 测试工位设置" FontSize="15" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,16"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="DUT工位数量" Style="{StaticResource FieldLabel}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="WizDUTCount" Minimum="1" Maximum="64" Value="4"
                                                IsSnapToTickEnabled="True" TickFrequency="1"
                                                ValueChanged="OnDUTCountChanged" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" x:Name="WizDUTCountLabel" Text="4" FontSize="16"
                                                   FontWeight="Bold" Foreground="#007ACC" Margin="12,0,0,0"
                                                   Width="30" TextAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="通信方式" Style="{StaticResource FieldLabel}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox x:Name="WizUseSerial" Content="串口通信" IsChecked="True" Margin="0,0,16,0" FontSize="12"/>
                                        <CheckBox x:Name="WizUseNetwork" Content="网络通信" FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 插件能力预览 -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="🔌 已安装的测试能力（插件）" FontSize="15" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,12"/>
                            <TextBlock x:Name="WizPluginSummary" Text="正在检测插件..." FontSize="12" Foreground="#888" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <ItemsControl x:Name="WizPluginList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F7F9FC" CornerRadius="6" Padding="12,8" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="🔌" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#888"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding Version}" FontSize="11" Foreground="#AAA"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="WizNoPluginHint" Text="💡 提示：安装更多插件可扩展测试能力（如串口通信、仪器控制等）"
                                       FontSize="11" Foreground="#F0AD4E" Margin="0,8,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ───── 第2步：测试步骤 ───── -->
            <ScrollViewer x:Name="Step2Panel" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                <StackPanel>
                    <!-- 快速添加区域 -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="➕ 添加测试步骤" FontSize="15" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,12"/>
                            <TextBlock Text="选择一种测试类型，填入命令和判定条件即可" FontSize="12" Foreground="#888" Margin="0,0,0,12"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0: 步骤名称 + 测试类型 -->
                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="步骤名称 *" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="WizStepName" Style="{StaticResource WizardTextBox}" Margin="0,0,0,10"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2">
                                    <TextBlock Text="测试类型 *" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="WizStepCategory" FontSize="13" Padding="6,6" Margin="0,0,0,10"
                                              SelectionChanged="OnStepCategoryChanged"/>
                                </StackPanel>

                                <!-- Row 1: 命令 -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3">
                                    <TextBlock Text="测试命令" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="WizStepCommand" Style="{StaticResource WizardTextBox}" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="WizCommandHint" Text="" FontSize="11" Foreground="#888"
                                               Margin="0,-6,0,8" TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- Row 2: 判定方式 + 判定值 -->
                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <TextBlock Text="结果判定方式" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="WizExpectedMode" FontSize="13" Padding="6,6" Margin="0,0,0,10">
                                        <ComboBoxItem Content="包含文本（推荐）" Tag="contains" IsSelected="True"/>
                                        <ComboBoxItem Content="完全匹配" Tag="equals"/>
                                        <ComboBoxItem Content="正则表达式" Tag="regex"/>
                                        <ComboBoxItem Content="不判定（仅执行）" Tag="none"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="2">
                                    <TextBlock Text="期望的结果内容" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="WizExpectedValue" Style="{StaticResource WizardTextBox}" Margin="0,0,0,10"/>
                                </StackPanel>

                                <!-- Row 3: 超时 -->
                                <StackPanel Grid.Row="3" Grid.Column="0">
                                    <TextBlock Text="超时时间" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="WizStepTimeout" FontSize="13" Padding="6,6" Margin="0,0,0,10">
                                        <ComboBoxItem Content="5 秒（快速命令）" Tag="5000" IsSelected="True"/>
                                        <ComboBoxItem Content="10 秒（普通命令）" Tag="10000"/>
                                        <ComboBoxItem Content="30 秒（耗时操作）" Tag="30000"/>
                                        <ComboBoxItem Content="60 秒（长时测试）" Tag="60000"/>
                                        <ComboBoxItem Content="120 秒（超长测试）" Tag="120000"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Row 3: Add Button -->
                                <StackPanel Grid.Row="3" Grid.Column="2" VerticalAlignment="Bottom" Margin="0,0,0,10">
                                    <Button Content="✚ 添加此步骤" Style="{StaticResource SuccessButton}" Click="AddWizardStep_Click"
                                            HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 已添加的步骤列表 -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="📋 已添加的测试步骤" FontSize="15" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <TextBlock x:Name="WizStepCountLabel" Text="共 0 步" FontSize="12" Foreground="#888"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <ItemsControl x:Name="WizStepList" Margin="0,12,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F7F9FC" CornerRadius="6" Padding="14,10" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="36"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- 序号 -->
                                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14" Background="#007ACC">
                                                    <TextBlock Text="{Binding Order}" FontSize="12" FontWeight="Bold"
                                                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <!-- 信息 -->
                                                <StackPanel Grid.Column="1" Margin="8,0">
                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"/>
                                                    <TextBlock FontSize="11" Foreground="#888">
                                                        <Run Text="{Binding CategoryLabel, Mode=OneWay}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding CommandPreview, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <!-- 上移 -->
                                                <Button Grid.Column="2" Content="▲" FontSize="10" Padding="6,2"
                                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                        Tag="{Binding Id}" Click="MoveWizStepUp_Click"/>
                                                <!-- 下移 -->
                                                <Button Grid.Column="3" Content="▼" FontSize="10" Padding="6,2"
                                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                        Tag="{Binding Id}" Click="MoveWizStepDown_Click"/>
                                                <!-- 删除 -->
                                                <Button Grid.Column="4" Content="✕" FontSize="12" Padding="6,2" Margin="4,0,0,0"
                                                        Foreground="#DC3545" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                        Tag="{Binding Id}" Click="RemoveWizStep_Click"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock x:Name="WizNoStepHint" Text="还没有添加任何测试步骤，请在上方选择类型并添加"
                                       FontSize="12" Foreground="#AAA" HorizontalAlignment="Center" Margin="0,20,0,20"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ───── 第3步：预览保存 ───── -->
            <ScrollViewer x:Name="Step3Panel" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                <StackPanel>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="📄 配置预览" FontSize="15" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,16"/>

                            <!-- 产品信息摘要 -->
                            <Border Background="#F0F7FF" CornerRadius="6" Padding="14,10" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="WizReviewIcon" Grid.Column="0" Text="📱" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock x:Name="WizReviewProductName" Text="" FontSize="16" FontWeight="Bold" Foreground="#1A1A2E"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock x:Name="WizReviewProductModel" Text="" FontSize="12" Foreground="#555"/>
                                            <TextBlock Text=" · " Foreground="#CCC"/>
                                            <TextBlock x:Name="WizReviewCategory" Text="" FontSize="12" Foreground="#555"/>
                                            <TextBlock Text=" · " Foreground="#CCC"/>
                                            <TextBlock x:Name="WizReviewDUTCount" Text="" FontSize="12" Foreground="#007ACC" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 步骤预览 -->
                            <TextBlock Text="测试流程" FontSize="13" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,8"/>
                            <ItemsControl x:Name="WizReviewStepList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <Border Width="24" Height="24" CornerRadius="12" Background="#007ACC" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding Order}" FontSize="11" FontWeight="Bold"
                                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding CategoryLabel, Mode=OneWay}" FontSize="11" Foreground="#888"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="💾 保存选项" FontSize="15" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,16"/>

                            <CheckBox x:Name="WizSaveAsDefault" Content="设为当前默认测试配置（覆盖 unified-config.json）"
                                      IsChecked="True" FontSize="12" Margin="0,0,0,8"/>
                            <CheckBox x:Name="WizExportCopy" Content="同时导出一份副本到文件"
                                      IsChecked="False" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <!-- 验证结果 -->
                    <Border x:Name="WizValidationPanel" Style="{StaticResource CardBorder}" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="WizValidationTitle" Text="" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock x:Name="WizValidationDetail" Text="" FontSize="12" Foreground="#666" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══════════ 底部导航栏 ═══════════ -->
        <Border Grid.Row="3" Background="White" Padding="24,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="-1" Opacity="0.06" Color="Gray"/>
            </Border.Effect>
            <Grid>
                <Button x:Name="BtnPrevious" Content="← 上一步" Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Left" Click="BtnPrevious_Click" Visibility="Collapsed"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Style="{StaticResource SecondaryButton}" Click="BtnCancel_Click" Margin="0,0,10,0"/>
                    <Button x:Name="BtnNext" Content="下一步 →" Style="{StaticResource PrimaryButton}" Click="BtnNext_Click"/>
                    <Button x:Name="BtnSave" Content="✓ 保存并应用" Style="{StaticResource SuccessButton}"
                            Click="BtnSave_Click" Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
