<Window x:Class="UTF.UI.PluginManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="插件管理" Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- 按钮样式 -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 标签样式 -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Tag样式 -->
        <Style x:Key="TagBorder" TargetType="Border">
            <Setter Property="Background" Value="#E3F2FD"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="0,0,4,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="White" Padding="20,15" Margin="0,0,0,10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="2" Opacity="0.1" Color="Gray"/>
            </Border.Effect>
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="🔌" FontSize="20" Margin="0,0,8,0"/>
                    <TextBlock Text="插件管理" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                    <Border x:Name="SummaryBadge" Background="#27AE60" CornerRadius="10" Padding="8,2" Margin="15,0,0,0">
                        <TextBlock x:Name="SummaryText" Text="已加载 0 个" Foreground="White" FontSize="11" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
                <Button Content="🔄 重新扫描" Style="{StaticResource ActionButton}"
                        HorizontalAlignment="Right" Click="RescanPlugins_Click"/>
            </Grid>
        </Border>

        <!-- 主体内容 -->
        <Grid Grid.Row="1" Margin="10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：插件列表 -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="2" Opacity="0.1" Color="Gray"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="插件列表" Style="{StaticResource SectionLabel}"/>

                    <!-- 搜索框 -->
                    <TextBox Grid.Row="1" x:Name="SearchBox"
                             Padding="8,6"
                             FontSize="12"
                             Margin="0,0,0,10"
                             TextChanged="SearchBox_TextChanged">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="BorderBrush" Value="#CCC"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter Property="BorderBrush" Value="#007ACC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- 插件列表 -->
                    <ListBox Grid.Row="2" x:Name="PluginListBox"
                             BorderThickness="0"
                             SelectionChanged="PluginListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Margin="0,2" Background="Transparent" CornerRadius="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 状态图标 -->
                                        <TextBlock Grid.Column="0" Text="{Binding StatusIcon}"
                                                   FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>

                                        <!-- 插件信息 -->
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="{Binding PluginId}" FontSize="10" Foreground="#888"/>
                                        </StackPanel>

                                        <!-- 版本和优先级 -->
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Version}" FontSize="10" Foreground="#555" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding Priority, StringFormat='P:{0}'}" FontSize="9" Foreground="#888" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 右侧：插件详情 -->
            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20" Margin="0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="2" Opacity="0.1" Color="Gray"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DetailPanel" Visibility="Collapsed">
                        <!-- 基本信息卡片 -->
                        <Border Background="#F8F9FA" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="基本信息" Style="{StaticResource SectionLabel}"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock x:Name="DetailName" Text="插件名称" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                                    <Border Background="#007ACC" CornerRadius="3" Padding="6,2" Margin="10,0,0,0">
                                        <TextBlock x:Name="DetailVersion" Text="v1.0.0" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="插件ID:" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DetailPluginId" Text="-" FontSize="12" Foreground="#333" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="API版本:" Style="{StaticResource FieldLabel}" Margin="0,8,0,4"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DetailApiVersion" Text="-" FontSize="12" Foreground="#333" Margin="0,8,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="优先级:" Style="{StaticResource FieldLabel}" Margin="0,8,0,4"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DetailPriority" Text="-" FontSize="12" Foreground="#333" Margin="0,8,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 能力矩阵卡片 -->
                        <Border Background="#F8F9FA" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="能力矩阵" Style="{StaticResource SectionLabel}"/>

                                <TextBlock Text="支持的步骤类型:" Style="{StaticResource FieldLabel}"/>
                                <ItemsControl x:Name="StepTypesList" Margin="0,0,0,10">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource TagBorder}">
                                                <TextBlock Text="{Binding}" FontSize="11" Foreground="#1976D2"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="支持的通道:" Style="{StaticResource FieldLabel}" Margin="0,8,0,4"/>
                                <ItemsControl x:Name="ChannelsList">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource TagBorder}" Background="#E8F5E9">
                                                <TextBlock Text="{Binding}" FontSize="11" Foreground="#388E3C"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- 加载状态卡片 -->
                        <Border x:Name="StatusCard" Background="#F8F9FA" CornerRadius="6" Padding="15">
                            <StackPanel>
                                <TextBlock Text="加载状态" Style="{StaticResource SectionLabel}"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="状态:" Style="{StaticResource FieldLabel}" Margin="0"/>
                                    <Border x:Name="StatusBadge" Background="#27AE60" CornerRadius="3" Padding="6,2" Margin="8,0,0,0">
                                        <TextBlock x:Name="DetailStatus" Text="已加载" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel x:Name="ErrorPanel" Visibility="Collapsed">
                                    <TextBlock Text="错误代码:" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock x:Name="DetailErrorCode" Text="-" FontSize="12" Foreground="#E74C3C" FontWeight="Bold" Margin="0,0,0,8"/>

                                    <TextBlock Text="错误信息:" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock x:Name="DetailErrorMessage" Text="-" FontSize="12" Foreground="#E74C3C" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Background="White" Padding="15,10" Margin="0,10,0,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="2" Opacity="0.1" Color="Gray"/>
            </Border.Effect>
            <Grid>
                <TextBlock x:Name="PluginDirectoryText" Text="插件目录: " FontSize="11" Foreground="#666" VerticalAlignment="Center"/>
                <Button Content="关闭" Style="{StaticResource ActionButton}"
                        HorizontalAlignment="Right" Click="Close_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
