<Window x:Class="UTF.UI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:UTF.UI.Localization"
        Title="{loc:Localize Login.Title, DefaultValue=用户登录 - Universal Test Framework}" 
        MinHeight="550" Height="600" Width="500" 
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        SizeToContent="Height"
        Background="#F5F5F5">
    
    <Window.Resources>
        <!-- 按钮样式 -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 输入框样式 -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3498DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 密码框样式 -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3498DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <!-- 背景 -->
        <Border Background="White" CornerRadius="10" Margin="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.3" Color="Gray"/>
            </Border.Effect>
            
            <Grid Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- 标题区域 -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,30">
                    <TextBlock Text="🔐" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Universal Test Framework" 
                             FontSize="18" 
                             FontWeight="Bold" 
                             Foreground="#2C3E50" 
                             HorizontalAlignment="Center"/>
                    <TextBlock Text="{loc:Localize Login.Title, DefaultValue=用户登录}" 
                             FontSize="14" 
                             Foreground="#7F8C8D" 
                             HorizontalAlignment="Center" 
                             Margin="0,5,0,0"/>
                </StackPanel>
                
                <!-- 登录表单 -->
                <StackPanel Grid.Row="1" Margin="0,0,0,20">
                    <!-- 语言选择 -->
                    <TextBlock Text="{loc:Localize Login.Language, DefaultValue=语言}" FontSize="12" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,5"/>
                    <ComboBox x:Name="LanguageComboBox" 
                            DisplayMemberPath="DisplayName"
                            SelectedValuePath="Code"
                            FontSize="14"
                            Padding="12,10"
                            BorderThickness="2"
                            BorderBrush="#E0E0E0"
                            Background="White"
                            Margin="0,0,0,15"
                            SelectionChanged="LanguageComboBox_SelectionChanged">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ComboBox">
                                            <Grid>
                                                <ToggleButton x:Name="ToggleButton"
                                                            Grid.Column="2"
                                                            Focusable="false"
                                                            IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                            ClickMode="Press">
                                                    <ToggleButton.Template>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                  BorderBrush="{TemplateBinding BorderBrush}" 
                                                                  BorderThickness="{TemplateBinding BorderThickness}" 
                                                                  CornerRadius="6">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition />
                                                                        <ColumnDefinition Width="20" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <ContentPresenter Grid.Column="0" 
                                                                                    Margin="12,10" 
                                                                                    HorizontalAlignment="Left" 
                                                                                    VerticalAlignment="Center" />
                                                                    <Path Grid.Column="1" 
                                                                        HorizontalAlignment="Center" 
                                                                        VerticalAlignment="Center" 
                                                                        Data="M 0 0 L 4 4 L 8 0 Z" 
                                                                        Fill="#666666" />
                                                                </Grid>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </ToggleButton.Template>
                                                </ToggleButton>
                                                <ContentPresenter x:Name="ContentSite"
                                                                IsHitTestVisible="False"
                                                                Content="{TemplateBinding SelectionBoxItem}"
                                                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                                ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                                Margin="12,10"
                                                                VerticalAlignment="Center"
                                                                HorizontalAlignment="Left" />
                                                <Popup x:Name="Popup"
                                                     Placement="Bottom"
                                                     IsOpen="{TemplateBinding IsDropDownOpen}"
                                                     AllowsTransparency="True"
                                                     Focusable="False"
                                                     PopupAnimation="Slide">
                                                    <Grid x:Name="DropDown"
                                                        SnapsToDevicePixels="True"
                                                        MinWidth="{TemplateBinding ActualWidth}"
                                                        MaxHeight="200">
                                                        <Border Background="White" 
                                                              BorderBrush="#E0E0E0" 
                                                              BorderThickness="2" 
                                                              CornerRadius="6">
                                                            <ScrollViewer Margin="4,6" SnapsToDevicePixels="True">
                                                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                                            </ScrollViewer>
                                                        </Border>
                                                    </Grid>
                                                </Popup>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter TargetName="ToggleButton" Property="BorderBrush" Value="#3498DB"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>
                    
                    <!-- 用户名 -->
                    <TextBlock Text="{loc:Localize Login.Username, DefaultValue=用户名}" FontSize="12" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,5"/>
                    <TextBox x:Name="UsernameTextBox" 
                           Style="{StaticResource ModernTextBox}"
                           Margin="0,0,0,15"/>
                    
                    <!-- 密码 -->
                    <TextBlock Text="{loc:Localize Login.Password, DefaultValue=密码}" FontSize="12" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="PasswordBox" 
                               Style="{StaticResource ModernPasswordBox}"
                               Margin="0,0,0,15"/>
                    
                    <!-- 记住我选项 -->
                    <CheckBox x:Name="RememberMeCheckBox" 
                            Content="{loc:Localize Login.RememberMe, DefaultValue=记住我}" 
                            FontSize="12" 
                            Foreground="#7F8C8D" 
                            Margin="0,0,0,10"/>
                </StackPanel>
                
                <!-- 状态信息 -->
                <StackPanel Grid.Row="2" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusTextBlock" 
                             Text="" 
                             FontSize="12" 
                             Foreground="Red" 
                             HorizontalAlignment="Center" 
                             Margin="0,0,0,10"
                             Visibility="Collapsed"/>
                             
                    <!-- 登录提示 -->
                    <Border Background="#E8F4FD" BorderBrush="#3498DB" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock x:Name="LoginHintTitle" Text="{loc:Localize Login.DefaultAccount, DefaultValue=💡 登录提示}" FontSize="12" FontWeight="Bold" Foreground="#2980B9" Margin="0,0,0,5"/>
                            <TextBlock x:Name="LoginHintText" Text="{loc:Localize Login.LoginHint, DefaultValue=请输入您的用户名和密码进行登录}" FontSize="11" Foreground="#34495E"/>
                            <TextBlock x:Name="LoginHintDefaultAdmin" Text="{loc:Localize Login.DefaultAdmin, DefaultValue=系统默认管理员}" FontSize="11" Foreground="#7F8C8D" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- 按钮区域 -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="LoginButton" 
                          Content="{loc:Localize Login.LoginButton, DefaultValue=🚀 登录}" 
                          Style="{StaticResource ModernButton}"
                          Background="#3498DB"
                          Width="120"
                          Click="LoginButton_Click"
                          IsDefault="True"/>
                    
                    <Button x:Name="CancelButton" 
                          Content="{loc:Localize Login.CancelButton, DefaultValue=❌ 取消}" 
                          Style="{StaticResource ModernButton}"
                          Background="#95A5A6"
                          Width="120"
                          Click="CancelButton_Click"
                          IsCancel="True"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
