<Window x:Class="UTF.UI.PermissionManagementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="权限管理" 
        Height="500" Width="700" 
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    
    <Window.Resources>
        <!-- 按钮样式 -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="10">
        <!-- 背景 -->
        <Border Background="White" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.2" Color="Gray"/>
            </Border.Effect>
            
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- 标题 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="🔐" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TitleText" Text="用户权限管理" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- 用户信息 -->
                <Border Grid.Row="1" Background="#ECF0F1" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="用户:" FontWeight="Bold" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1" x:Name="UserNameText" Text="" Margin="0,0,20,0"/>
                        
                        <TextBlock Grid.Column="2" Text="当前角色:" FontWeight="Bold" Margin="0,0,10,0"/>
                        <ComboBox Grid.Column="3" x:Name="RoleComboBox" Width="120" HorizontalAlignment="Left" SelectionChanged="RoleComboBox_SelectionChanged">
                            <ComboBoxItem Content="超级管理员" Tag="SuperAdmin"/>
                            <ComboBoxItem Content="管理员" Tag="Admin"/>
                            <ComboBoxItem Content="工程师" Tag="Engineer"/>
                            <ComboBoxItem Content="技术员" Tag="Technician"/>
                            <ComboBoxItem Content="操作员" Tag="Operator"/>
                            <ComboBoxItem Content="观察者" Tag="Observer"/>
                        </ComboBox>
                    </Grid>
                </Border>
                
                <!-- 权限列表 -->
                <TabControl Grid.Row="2">
                    <TabItem Header="🔧 系统权限">
                        <ScrollViewer Margin="10">
                            <StackPanel x:Name="SystemPermissionsPanel">
                                <CheckBox Content="系统管理" Tag="SystemAdmin" Margin="0,5"/>
                                <CheckBox Content="用户管理" Tag="UserManagement" Margin="0,5"/>
                                <CheckBox Content="系统配置" Tag="SystemConfig" Margin="0,5"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    
                    <TabItem Header="🔬 设备权限">
                        <ScrollViewer Margin="10">
                            <StackPanel x:Name="DevicePermissionsPanel">
                                <CheckBox Content="设备管理" Tag="DeviceManagement" Margin="0,5"/>
                                <CheckBox Content="设备配置" Tag="DeviceConfig" Margin="0,5"/>
                                <CheckBox Content="设备校准" Tag="DeviceCalibration" Margin="0,5"/>
                                <CheckBox Content="设备发现" Tag="DeviceDiscovery" Margin="0,5"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    
                    <TabItem Header="📋 测试权限">
                        <ScrollViewer Margin="10">
                            <StackPanel x:Name="TestPermissionsPanel">
                                <CheckBox Content="测试计划管理" Tag="TestPlanManagement" Margin="0,5"/>
                                <CheckBox Content="创建测试计划" Tag="TestPlanCreate" Margin="0,5"/>
                                <CheckBox Content="编辑测试计划" Tag="TestPlanEdit" Margin="0,5"/>
                                <CheckBox Content="删除测试计划" Tag="TestPlanDelete" Margin="0,5"/>
                                <CheckBox Content="测试执行" Tag="TestExecution" Margin="0,5"/>
                                <CheckBox Content="启动测试" Tag="TestStart" Margin="0,5"/>
                                <CheckBox Content="停止测试" Tag="TestStop" Margin="0,5"/>
                                <CheckBox Content="暂停测试" Tag="TestPause" Margin="0,5"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    
                    <TabItem Header="📱 DUT权限">
                        <ScrollViewer Margin="10">
                            <StackPanel x:Name="DutPermissionsPanel">
                                <CheckBox Content="DUT管理" Tag="DutManagement" Margin="0,5"/>
                                <CheckBox Content="DUT配置" Tag="DutConfig" Margin="0,5"/>
                                <CheckBox Content="DUT连接" Tag="DutConnection" Margin="0,5"/>
                                <CheckBox Content="多DUT测试" Tag="MultiDutTest" Margin="0,5"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    
                    <TabItem Header="📊 数据权限">
                        <ScrollViewer Margin="10">
                            <StackPanel x:Name="DataPermissionsPanel">
                                <CheckBox Content="数据查看" Tag="DataView" Margin="0,5"/>
                                <CheckBox Content="数据导出" Tag="DataExport" Margin="0,5"/>
                                <CheckBox Content="数据删除" Tag="DataDelete" Margin="0,5"/>
                                <CheckBox Content="报告生成" Tag="ReportGeneration" Margin="0,5"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    
                    <TabItem Header="📝 日志权限">
                        <ScrollViewer Margin="10">
                            <StackPanel x:Name="LogPermissionsPanel">
                                <CheckBox Content="日志查看" Tag="LogView" Margin="0,5"/>
                                <CheckBox Content="日志导出" Tag="LogExport" Margin="0,5"/>
                                <CheckBox Content="日志清理" Tag="LogClear" Margin="0,5"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
                
                <!-- 按钮区域 -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button Content="💾 保存" Style="{StaticResource ActionButton}" Background="#27AE60" Click="SaveBtn_Click"/>
                    <Button Content="🔄 重置" Style="{StaticResource ActionButton}" Background="#F39C12" Click="ResetBtn_Click"/>
                    <Button Content="❌ 取消" Style="{StaticResource ActionButton}" Background="#95A5A6" Click="CancelBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
