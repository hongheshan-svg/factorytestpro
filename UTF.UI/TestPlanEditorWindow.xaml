<Window x:Class="UTF.UI.TestPlanEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="测试计划编辑器" Height="600" Width="800"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">
    
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 工具栏 -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button Content="📁 打开" Margin="5,0" Padding="10,5" Click="OpenPlan_Click"/>
                <Button Content="💾 保存" Margin="5,0" Padding="10,5" Click="SavePlan_Click"/>
                <Button Content="🆕 新建" Margin="5,0" Padding="10,5" Click="NewPlan_Click"/>
                <Separator Margin="10,0"/>
                <Button Content="▶️ 运行测试" Margin="5,0" Padding="10,5" Background="#28A745" Foreground="White" Click="RunTest_Click"/>
            </StackPanel>
        </Border>
        
        <!-- 主编辑区域 -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧：测试计划信息 -->
            <GroupBox Grid.Column="0" Header="测试计划信息" Margin="0,0,5,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <Label Content="计划名称:"/>
                        <TextBox Name="PlanNameTextBox" Margin="0,0,0,10"/>
                        
                        <Label Content="描述:"/>
                        <TextBox Name="DescriptionTextBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10"/>
                        
                        <Label Content="测试类型:"/>
                        <ComboBox Name="TestTypeComboBox" Margin="0,0,0,10" IsEditable="True">
                            <ComboBoxItem Content="功能测试"/>
                            <ComboBoxItem Content="性能测试"/>
                            <ComboBoxItem Content="稳定性测试"/>
                            <ComboBoxItem Content="兼容性测试"/>
                        </ComboBox>
                        
                        <Label Content="预计时长(分钟):"/>
                        <TextBox Name="EstimatedDurationTextBox" Margin="0,0,0,10"/>
                        
                        <Label Content="优先级:"/>
                        <ComboBox Name="PriorityComboBox" Margin="0,0,0,10">
                            <ComboBoxItem Content="低"/>
                            <ComboBoxItem Content="中" IsSelected="True"/>
                            <ComboBoxItem Content="高"/>
                            <ComboBoxItem Content="紧急"/>
                        </ComboBox>
                        
                        <CheckBox Name="AutoRunCheckBox" Content="自动运行" Margin="0,0,0,10"/>
                        <CheckBox Name="GenerateReportCheckBox" Content="自动生成报告" IsChecked="True" Margin="0,0,0,10"/>
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>
            
            <!-- 右侧：测试步骤编辑 -->
            <GroupBox Grid.Column="1" Header="测试步骤" Margin="5,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 步骤操作工具栏 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
                        <Button Content="➕ 添加步骤" Margin="5,0" Padding="8,4" Click="AddStep_Click"/>
                        <Button Content="➖ 删除步骤" Margin="5,0" Padding="8,4" Click="RemoveStep_Click"/>
                        <Button Content="⬆️ 上移" Margin="5,0" Padding="8,4" Click="MoveStepUp_Click"/>
                        <Button Content="⬇️ 下移" Margin="5,0" Padding="8,4" Click="MoveStepDown_Click"/>
                    </StackPanel>
                    
                    <!-- 测试步骤列表 -->
                    <DataGrid Grid.Row="1" Name="TestStepsDataGrid" Margin="10"
                              AutoGenerateColumns="False" CanUserAddRows="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="步骤名称" Binding="{Binding StepName}" Width="140"/>
                            <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="160"/>
                            <DataGridTextColumn Header="StepType" Binding="{Binding StepType}" Width="90"/>
                            <DataGridTextColumn Header="Channel" Binding="{Binding Channel}" Width="90"/>
                            <DataGridTextColumn Header="Command" Binding="{Binding Command}" Width="180"/>
                            <DataGridTextColumn Header="Expected" Binding="{Binding Expected}" Width="140"/>
                            <DataGridTextColumn Header="超时(秒)" Binding="{Binding TimeoutSeconds}" Width="80"/>
                            <DataGridCheckBoxColumn Header="必需" Binding="{Binding IsRequired}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>
        </Grid>
        
        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Background="#2D2D30" Padding="10,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Name="StatusText" Text="就绪" Foreground="White"/>
                <TextBlock Text=" | " Foreground="Gray" Margin="10,0"/>
                <TextBlock Name="StepCountText" Text="步骤数: 0" Foreground="White"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
