<Window x:Class="UTF.UI.DUTDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DUT测试详情" 
        Height="700" Width="1000" 
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    
    <Window.Resources>
        <!-- 步骤状态转换器 -->
        <Style x:Key="StepStatusStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="2"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Pending">
                    <Setter Property="Background" Value="#95A5A6"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Running">
                    <Setter Property="Background" Value="#F39C12"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Completed">
                    <Setter Property="Background" Value="#27AE60"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Failed">
                    <Setter Property="Background" Value="#E74C3C"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <!-- 测试结果样式 -->
        <Style x:Key="ResultStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="2"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Result}" Value="Pass">
                    <Setter Property="Background" Value="#27AE60"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Result}" Value="Fail">
                    <Setter Property="Background" Value="#E74C3C"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Result}" Value="NotRun">
                    <Setter Property="Background" Value="#BDC3C7"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <!-- 日志级别样式 -->
        <Style x:Key="LogLevelStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="Margin" Value="2,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Level}" Value="Debug">
                    <Setter Property="Background" Value="#95A5A6"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Info">
                    <Setter Property="Background" Value="#3498DB"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Warning">
                    <Setter Property="Background" Value="#F39C12"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Error">
                    <Setter Property="Background" Value="#E74C3C"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Critical">
                    <Setter Property="Background" Value="#8E44AD"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题和DUT基本信息 -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="2" Opacity="0.1" Color="Gray"/>
            </Border.Effect>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- DUT基本信息 -->
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="📱" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="DutTitleText" Text="DUT详细信息" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="DUT ID:" FontWeight="Bold" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DutIdText" Text="" Margin="0,0,20,4"/>
                        
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="DUT名称:" FontWeight="Bold" Margin="0,0,8,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" x:Name="DutNameText" Text="" Margin="0,0,20,4"/>
                        
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="当前状态:" FontWeight="Bold" Margin="0,0,8,4"/>
                        <Border Grid.Row="0" Grid.Column="5" x:Name="StatusBorder" CornerRadius="4" Padding="8,2">
                            <TextBlock x:Name="StatusText" Text="" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Border>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="开始时间:" FontWeight="Bold" Margin="0,0,8,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="StartTimeText" Text="" Margin="0,0,20,0"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="执行时长:" FontWeight="Bold" Margin="0,0,8,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="3" x:Name="DurationText" Text="" Margin="0,0,20,0"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="4" Text="当前进度:" FontWeight="Bold" Margin="0,0,8,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="5" x:Name="ProgressText" Text="" FontWeight="Bold"/>
                    </Grid>
                </StackPanel>
                
                <!-- 控制按钮 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="RefreshBtn" Content="🔄 刷新" Margin="5" Padding="10,5" Click="RefreshBtn_Click"/>
                    <Button x:Name="ExportLogBtn" Content="📤 导出日志" Margin="5" Padding="10,5" Click="ExportLogBtn_Click"/>
                    <Button x:Name="CloseBtn" Content="❌ 关闭" Margin="5" Padding="10,5" Click="CloseBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- 主内容区域 -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <!-- 测试步骤标签页 -->
            <TabItem Header="📋 测试步骤">
                <Border Background="White" CornerRadius="8" Margin="0,5,0,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="4" ShadowDepth="2" Opacity="0.1" Color="Gray"/>
                    </Border.Effect>
                    
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- 步骤统计 -->
                        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                            <UniformGrid Columns="5">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="总步骤" FontSize="12" Foreground="#6C757D" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TotalStepsText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#495057" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="等待中" FontSize="12" Foreground="#6C757D" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="PendingStepsText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#6C757D" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="执行中" FontSize="12" Foreground="#6C757D" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="RunningStepsText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#F39C12" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="已通过" FontSize="12" Foreground="#6C757D" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="PassedStepsText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="已失败" FontSize="12" Foreground="#6C757D" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="FailedStepsText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#DC3545" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </UniformGrid>
                        </Border>
                        
                        <!-- 测试步骤列表 -->
                        <DataGrid Grid.Row="1" x:Name="TestStepsDataGrid" 
                                AutoGenerateColumns="False" 
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                GridLinesVisibility="Horizontal"
                                HeadersVisibility="Column"
                                AlternatingRowBackground="#F8F9FA"
                                SelectionMode="Single"
                                MouseDoubleClick="TestStepsDataGrid_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="步骤" Binding="{Binding StepIndex}" Width="50"/>
                                <DataGridTextColumn Header="步骤名称" Binding="{Binding StepName}" Width="150"/>
                                <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="200"/>
                                <DataGridTemplateColumn Header="状态" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource StepStatusStyle}">
                                                <TextBlock Text="{Binding StatusDisplay}" Foreground="White" FontWeight="Bold" TextAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="结果" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource ResultStyle}">
                                                <TextBlock Text="{Binding ResultDisplay}" Foreground="White" FontWeight="Bold" TextAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="耗时" Binding="{Binding DurationDisplay}" Width="80"/>
                                <DataGridTextColumn Header="结果信息" Binding="{Binding ResultMessage}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>
            
            <!-- DUT日志标签页 -->
            <TabItem Header="📝 测试日志">
                <Border Background="White" CornerRadius="8" Margin="0,5,0,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="4" ShadowDepth="2" Opacity="0.1" Color="Gray"/>
                    </Border.Effect>
                    
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- 日志过滤器 -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="日志级别:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox x:Name="LogLevelFilter" Width="100" SelectionChanged="LogLevelFilter_SelectionChanged">
                                <ComboBoxItem Content="全部" IsSelected="True"/>
                                <ComboBoxItem Content="调试"/>
                                <ComboBoxItem Content="信息"/>
                                <ComboBoxItem Content="警告"/>
                                <ComboBoxItem Content="错误"/>
                                <ComboBoxItem Content="严重"/>
                            </ComboBox>
                            
                            <TextBlock Text="测试步骤:" VerticalAlignment="Center" Margin="20,0,10,0"/>
                            <ComboBox x:Name="StepFilter" Width="150" SelectionChanged="StepFilter_SelectionChanged">
                                <ComboBoxItem Content="全部步骤" IsSelected="True"/>
                            </ComboBox>
                            
                            <Button x:Name="ClearLogBtn" Content="🗑️ 清除日志" Margin="20,0,0,0" Padding="8,4" Click="ClearLogBtn_Click"/>
                            <Button x:Name="AutoScrollBtn" Content="📜 自动滚动" Margin="10,0,0,0" Padding="8,4" Click="AutoScrollBtn_Click" Background="#28A745" Foreground="White"/>
                        </StackPanel>
                        
                        <!-- 日志列表 -->
                        <DataGrid Grid.Row="1" x:Name="LogDataGrid" 
                                AutoGenerateColumns="False" 
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                GridLinesVisibility="None"
                                HeadersVisibility="Column"
                                AlternatingRowBackground="#F8F9FA"
                                FontFamily="Consolas"
                                FontSize="11"
                                RowHeight="20">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="时间" Binding="{Binding TimeDisplay}" Width="80"/>
                                <DataGridTemplateColumn Header="级别" Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource LogLevelStyle}">
                                                <TextBlock Text="{Binding LevelDisplay}" Foreground="White" FontWeight="Bold" FontSize="9" TextAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="步骤" Binding="{Binding StepName}" Width="100"/>
                                <DataGridTextColumn Header="消息" Binding="{Binding FullMessage}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>
            
            <!-- 实时监控标签页 -->
            <TabItem Header="📊 实时监控">
                <Border Background="White" CornerRadius="8" Margin="0,5,0,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="4" ShadowDepth="2" Opacity="0.1" Color="Gray"/>
                    </Border.Effect>
                    
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- 实时状态指示器 -->
                        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                            <UniformGrid Columns="4">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="CPU使用率" FontSize="12" Foreground="#6C757D" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="CpuUsageText" Text="0%" FontSize="16" FontWeight="Bold" Foreground="#007BFF" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="内存使用" FontSize="12" Foreground="#6C757D" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="MemoryUsageText" Text="0MB" FontSize="16" FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="通信状态" FontSize="12" Foreground="#6C757D" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="CommStatusText" Text="正常" FontSize="16" FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="错误计数" FontSize="12" Foreground="#6C757D" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="ErrorCountText" Text="0" FontSize="16" FontWeight="Bold" Foreground="#DC3545" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </UniformGrid>
                        </Border>
                        
                        <!-- 性能图表区域 -->
                        <Grid Grid.Row="1">
                            <TextBlock Text="📈 性能监控图表区域" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#6C757D"/>
                            <TextBlock Text="(可集成实时图表组件显示DUT性能曲线)" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#ADB5BD" Margin="0,25,0,0"/>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
        
        <!-- 状态栏 -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15,10" Margin="0,10,0,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="2" Opacity="0.1" Color="Gray"/>
            </Border.Effect>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="StatusBarText" Grid.Column="0" Text="就绪" VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="最后更新:" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LastUpdateText" Text="" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
