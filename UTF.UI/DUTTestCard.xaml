<UserControl x:Class="UTF.UI.DUTTestCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <UserControl.Resources>
        <!-- 状态样式 -->
        <Style x:Key="StatusBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
        
        <Style x:Key="PassBadge" TargetType="Border" BasedOn="{StaticResource StatusBadge}">
            <Setter Property="Background" Value="#4CAF50"/>
        </Style>
        
        <Style x:Key="FailBadge" TargetType="Border" BasedOn="{StaticResource StatusBadge}">
            <Setter Property="Background" Value="#F44336"/>
        </Style>
        
        <Style x:Key="RunningBadge" TargetType="Border" BasedOn="{StaticResource StatusBadge}">
            <Setter Property="Background" Value="#FF9800"/>
        </Style>
        
        <Style x:Key="WaitingBadge" TargetType="Border" BasedOn="{StaticResource StatusBadge}">
            <Setter Property="Background" Value="#9E9E9E"/>
        </Style>
    </UserControl.Resources>
    
    <Border Background="White" 
            BorderBrush="#E0E0E0" 
            BorderThickness="1" 
            CornerRadius="8" 
            Margin="5" 
            Padding="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="4" 
                            ShadowDepth="2" 
                            Opacity="0.2" 
                            Color="Gray"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- DUT标题和状态 -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="DutIdText" 
                             Text="DUT_01" 
                             FontSize="16" 
                             FontWeight="Bold" 
                             Foreground="#2C3E50"/>
                    <TextBlock x:Name="DutNameText" 
                             Text="iPhone 15 Pro" 
                             FontSize="12" 
                             Foreground="#7F8C8D" 
                             Margin="0,2,0,0"/>
                </StackPanel>
                
                <Border x:Name="StatusBadge" 
                        Grid.Column="1" 
                        Style="{StaticResource RunningBadge}">
                    <TextBlock x:Name="StatusText" 
                             Text="测试中" 
                             Foreground="White" 
                             FontSize="10" 
                             FontWeight="Bold" 
                             TextAlignment="Center"/>
                </Border>
            </Grid>
            
            <!-- 当前测试步骤 -->
            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                         Text="当前步骤: " 
                         FontSize="11" 
                         Foreground="#34495E" 
                         FontWeight="SemiBold"/>
                <TextBlock x:Name="CurrentStepText" 
                         Grid.Column="1" 
                         Text="电池测试" 
                         FontSize="11" 
                         Foreground="#2C3E50"/>
            </Grid>
            
            <!-- 进度条和进度文本 -->
            <Grid Grid.Row="2" Margin="0,0,0,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" 
                             Text="测试进度" 
                             FontSize="10" 
                             Foreground="#7F8C8D"/>
                    <TextBlock x:Name="ProgressText" 
                             Grid.Column="1" 
                             Text="2/5" 
                             FontSize="10" 
                             Foreground="#2C3E50" 
                             FontWeight="Bold"/>
                </Grid>
                
                <ProgressBar x:Name="TestProgressBar" 
                           Grid.Row="1" 
                           Height="6" 
                           Value="40" 
                           Maximum="100" 
                           Background="#ECEFF1" 
                           Foreground="#2196F3"/>
            </Grid>
            
            <!-- 测试结果和时间信息 -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="结果: " 
                             FontSize="10" 
                             Foreground="#7F8C8D" 
                             VerticalAlignment="Center"/>
                    <Border x:Name="ResultBadge" 
                            Style="{StaticResource RunningBadge}">
                        <TextBlock x:Name="ResultText" 
                                 Text="执行中" 
                                 Foreground="White" 
                                 FontSize="9" 
                                 FontWeight="Bold"/>
                    </Border>
                </StackPanel>
                
                <TextBlock x:Name="DurationText" 
                         Grid.Column="1" 
                         Text="02:30" 
                         FontSize="10" 
                         Foreground="#7F8C8D" 
                         Margin="8,0,8,0" 
                         VerticalAlignment="Center"/>
                
                <Border Grid.Column="2" 
                        Background="#ECEFF1" 
                        CornerRadius="3" 
                        Padding="4,1">
                    <TextBlock x:Name="StartTimeText" 
                             Text="14:30" 
                             FontSize="9" 
                             Foreground="#546E7A"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
